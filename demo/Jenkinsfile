// For WINDOWS
pipeline {
agent any


environment {
    APP_NAME   = 'splitwise-backend'
    IMAGE_NAME = "adarsh0503/${APP_NAME}"
    IMAGE_TAG  = "${BUILD_NUMBER}"
}

tools {
    maven 'Maven 3.9'
    jdk 'JDK 17'
}

stages {

    stage('Checkout') {
        steps {
            echo '📥 Checking out source code...'
            checkout scm
        }
    }

    stage('Build') {
        steps {
            echo '🔨 Building application...'
            dir('demo') {
                bat 'mvn clean compile'
            }
        }
    }

    stage('Test') {
        steps {
            echo '🧪 Running unit tests...'
            dir('demo') {
                bat 'mvn test'
            }
        }
        post {
            always {
                junit 'demo/target/surefire-reports/*.xml'
            }
        }
    }

    stage('Code Quality Check') {
        steps {
            echo '🔍 Running verification...'
            dir('demo') {
                bat 'mvn verify -DskipTests'
            }
        }
    }

    stage('Package') {
        steps {
            echo '📦 Packaging JAR...'
            dir('demo') {
                bat 'mvn package -DskipTests'
            }

            archiveArtifacts artifacts: 'demo/target/*.jar', fingerprint: true
        }
    }
}

post {
    success {
        echo "✅ Pipeline SUCCESS — Build #${BUILD_NUMBER}"
    }

    failure {
        echo "❌ Pipeline FAILED — Build #${BUILD_NUMBER}"
    }

    always {
        cleanWs()
    }
}


}
