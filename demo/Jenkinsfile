pipeline {
agent any

```
environment {
    APP_NAME    = 'splitwise-backend'
    IMAGE_NAME  = "adarsh0503/${APP_NAME}"
    IMAGE_TAG   = "${BUILD_NUMBER}"
}

tools {
    maven 'Maven 3.9'
    jdk   'JDK 21'
}

stages {

    stage('Checkout') {
        steps {
            echo '📥 Checking out source code...'
            checkout scm
        }
    }

    stage('Build') {
        steps {
            echo '🔨 Building application...'
            dir('demo') {
                sh 'mvn clean compile -q'
            }
        }
    }

    stage('Test') {
        steps {
            echo '🧪 Running unit tests...'
            dir('demo') {
                sh 'mvn test'
            }
        }
        post {
            always {
                junit 'demo/target/surefire-reports/*.xml'
            }
        }
    }

    stage('Code Quality Check') {
        steps {
            echo '🔍 Checking for compilation warnings...'
            dir('demo') {
                sh 'mvn verify -DskipTests -q'
            }
        }
    }

    stage('Package') {
        steps {
            echo '📦 Packaging JAR...'
            dir('demo') {
                sh 'mvn package -DskipTests -q'
            }

            archiveArtifacts artifacts: 'demo/target/*.jar', fingerprint: true
        }
    }
}

post {
    success {
        echo "✅ Pipeline SUCCESS — Build #${BUILD_NUMBER}"
    }

    failure {
        echo "❌ Pipeline FAILED — Build #${BUILD_NUMBER}"
    }

    always {
        cleanWs()
    }
}
```

}



